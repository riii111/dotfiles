session_name: c1
start_directory: /Users/{{ .chezmoi.username }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}

options:
  status-left: "[c1] Ctrl+b w:list | f:follow | ':number | z:zoom | [:scroll | d:detach "
  status-left-length: 80
  status-right: ""
  remain-on-exit: on
  automatic-rename: off

windows:
  - window_name: dashboard
    layout: main-vertical
    options:
      main-pane-width: 50%
    panes:
      - shell_command:
          - /Users/{{ .chezmoi.username }}/.config/mux/core/mux-launcher c1
      - shell_command:
          - /Users/{{ .chezmoi.username }}/.config/mux/core/mux-monitor c1

  - window_name: app-api
    start_directory: /Users/{{ .chezmoi.username }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}/backend
    panes:
      - shell_command:
          - echo "=== app-api ===" && echo "Waiting for start command..."

