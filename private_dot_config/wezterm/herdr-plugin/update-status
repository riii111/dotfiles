#!/bin/sh
set -eu

if [ -n "${WEZTERM_GIT_STATUS_BRIDGE_BIN:-}" ]; then
	bin=$WEZTERM_GIT_STATUS_BRIDGE_BIN
elif command -v wezterm-git-status-bridge >/dev/null 2>&1; then
	bin=$(command -v wezterm-git-status-bridge)
else
	echo "wezterm-git-status-bridge: set WEZTERM_GIT_STATUS_BRIDGE_BIN or install wezterm-git-status-bridge in PATH" >&2
	exit 127
fi

herdr_bin=
if [ -n "${HERDR_BIN_PATH:-}" ]; then
	herdr_bin=$HERDR_BIN_PATH
elif command -v herdr >/dev/null 2>&1; then
	herdr_bin=$(command -v herdr)
fi

if [ -n "$herdr_bin" ]; then
	event_json=$("$herdr_bin" pane list 2>/dev/null) || event_json=
	if [ -n "$event_json" ]; then
		exec "$bin" update --event-json "$event_json"
	fi
fi

if [ -n "${HERDR_PLUGIN_EVENT_JSON:-}" ]; then
	exec "$bin" update --event-json "$HERDR_PLUGIN_EVENT_JSON"
fi

exec "$bin" update
