#!/bin/sh
set -eu

cache_home=${XDG_CACHE_HOME:-"$HOME/.cache"}
cache_dir="$cache_home/wezterm"
cache_file="$cache_dir/herdr-git-info"

json=${HERDR_PLUGIN_EVENT_JSON:-}
pane_id=$(
	printf '%s' "$json" | jq -r '
    .pane.pane_id //
    .focused_pane.pane_id //
    .result.pane.pane_id //
    empty
  ' 2>/dev/null || true
)
cwd=$(
	printf '%s' "$json" | jq -r '
    .pane.foreground_cwd //
    .pane.cwd //
    .focused_pane.foreground_cwd //
    .focused_pane.cwd //
    .result.pane.foreground_cwd //
    .result.pane.cwd //
    empty
  ' 2>/dev/null || true
)

if [ -z "$pane_id" ] || [ -z "$cwd" ]; then
	herdr_bin=${HERDR_BIN_PATH:-herdr}
	current=$("$herdr_bin" pane list 2>/dev/null || true)
	if [ -n "$current" ]; then
		pane_id=${pane_id:-$(printf '%s' "$current" | jq -r '.result.panes[]? | select(.focused == true) | .pane_id' 2>/dev/null || true)}
		cwd=${cwd:-$(printf '%s' "$current" | jq -r '.result.panes[]? | select(.focused == true) | .foreground_cwd // .cwd' 2>/dev/null || true)}
	fi
fi

[ -n "$pane_id" ] || exit 0
[ -n "$cwd" ] || exit 0

at=$(date +%s)
present=0
repo=
ref=
flags=

if root=$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null); then
	git_dir=$(git -C "$cwd" rev-parse --git-dir 2>/dev/null || true)
	common_dir=$(git -C "$cwd" rev-parse --git-common-dir 2>/dev/null || true)
	if [ -n "$git_dir" ] && [ -n "$common_dir" ]; then
		if ref=$(git -C "$cwd" symbolic-ref --short HEAD 2>/dev/null); then
			detached=0
		else
			ref=$(git -C "$cwd" rev-parse --short HEAD 2>/dev/null || true)
			detached=1
		fi

		if [ -n "$ref" ]; then
			dirty=0
			git -C "$cwd" diff --quiet 2>/dev/null || dirty=1
			[ "$dirty" = 0 ] && { git -C "$cwd" diff --quiet --cached 2>/dev/null || dirty=1; }
			[ "$dirty" = 0 ] && [ -n "$(git -C "$cwd" ls-files --others --exclude-standard --directory --no-empty-directory 2>/dev/null | head -n 1)" ] && dirty=1

			case "$git_dir" in /*) ;; *) git_dir="$root/$git_dir" ;; esac
			case "$common_dir" in /*) ;; *) common_dir="$root/$common_dir" ;; esac

			[ "$detached" = 1 ] && flags="${flags}D"
			[ "$dirty" = 1 ] && flags="${flags}d"
			[ "$(realpath "$git_dir")" != "$(realpath "$common_dir")" ] && flags="${flags}w"
			{ [ -d "$git_dir/rebase-merge" ] || [ -d "$git_dir/rebase-apply" ]; } && flags="${flags}R"
			[ -f "$git_dir/CHERRY_PICK_HEAD" ] && flags="${flags}C"

			present=1
			repo=${root##*/}
		fi
	fi
fi

mkdir -p "$cache_dir"
tmp="$cache_file.$$"
printf 'herdrgit1\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$at" "$pane_id" "$cwd" "$present" "$repo" "$ref" "$flags" >"$tmp"
mv "$tmp" "$cache_file"
