theme = Black Metal (Bathory)

#font-family = UDEV Gothic
font-family = DroidSansM Nerd Font Mono
font-size = 14

window-padding-x = 20
window-padding-y = 5
window-padding-balance = true
window-theme = ghostty
background-opacity = 0.45
background-blur-radius = 20
custom-shader = ~/.config/ghostty/passthrough.glsl
macos-titlebar-style = transparent
macos-icon = holographic

window-theme = dark

# Global hotkeys
keybind = "global:ctrl+cmd+g=toggle_quick_terminal"

# Font size (cmux overrides the default, so re-declare explicitly)
keybind = super+==increase_font_size:1
keybind = super++=increase_font_size:1
keybind = super+-=decrease_font_size:1
keybind = super+0=reset_font_size

# for nvim / for Claude Code CLI
keybind = super+right=unbind
keybind = super+down=unbind
keybind = super+alt+right=unbind
keybind = super+alt+left=unbind
keybind = super+shift+v=unbind
keybind = super+alt+down=unbind
keybind = super+alt+up=unbind

# Pane navigation
keybind = super+alt+h=resize_split:left,40
keybind = super+alt+j=resize_split:down,40
keybind = super+alt+k=resize_split:up,40
keybind = super+alt+l=resize_split:right,40
keybind = super+z=toggle_split_zoom
# Claude Code shortcuts (Alt+T=thinking, Alt+P=model switch)
macos-option-as-alt = true
# JIS keyboard: Option+¥ produces | and \ (broken by macos-option-as-alt)
keybind = alt+¥=text:|
keybind = alt+shift+|=text:\u{005c}

# for tmux
term = xterm-ghostty
keybind = shift+enter=text:\x1b\r
