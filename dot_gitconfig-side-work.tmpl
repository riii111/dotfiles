{{- /* Personal-machine only: side-work identity + SSH signing for repos under side_work_org */ -}}
{{- if eq .type "personal" }}
# Side-work account override: company email + SSH signing
# Generated by chezmoi - do not edit directly

[user]
	email = {{ .git_email_side_work }}
	signingKey = {{ .git_signing_key_side_work }}

[gpg]
	format = ssh

[commit]
	gpgsign = true
{{- end }}
