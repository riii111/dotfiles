sourceDir = "{{ .chezmoi.homeDir }}/ghq/github.com/riii111/dotfiles"

[data]
{{- if eq .chezmoi.hostname "riii111" }}
    type = "personal"
    git_email = {{ promptStringOnce . "git_email" "Git email for this machine (global default, e.g. GitHub noreply)" | quote }}
    git_email_side_work = {{ promptStringOnce . "git_email_side_work" "Git email for side-work repos under side_work_org" | quote }}
    git_name = "riii111"
    git_signingkey = "059E3467BC399937"
    git_signing_key_side_work = {{ promptStringOnce . "git_signing_key_side_work" "SSH public key path for side-work commit signing (e.g. ~/.ssh/id_ed25519.pub)" | quote }}
    side_work_org = {{ promptStringOnce . "side_work_org" "GitHub org name for side work" | quote }}
    side_work_project = {{ promptStringOnce . "side_work_project" "Project name for side work" | quote }}
{{- else }}
    type = "work"
    git_email = {{ promptStringOnce . "git_email" "Git email for this machine" | quote }}
    git_name = {{ promptStringOnce . "git_name" "Git name for this machine" | quote }}
    gh_work_org = {{ promptStringOnce . "gh_work_org" "GitHub org name for work" | quote }}
    gh_work_user = {{ promptStringOnce . "gh_work_user" "GitHub username for work" | quote }}
    gcp_project = {{ promptStringOnce . "gcp_project" "GCP project for prod-errors" | quote }}
    work_project = {{ promptStringOnce . "work_project" "Main project name for work" | quote }}
{{- end }}
