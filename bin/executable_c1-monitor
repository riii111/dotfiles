#!/usr/bin/env bash
#
# c1-monitor - Service status monitor for Contract One TUI dashboard
# Displays real-time status of all services in a 2-column layout
#

set -euo pipefail

SESSION_NAME="c1"
REFRESH_INTERVAL=1

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
NC=$'\033[0m'
BOLD=$'\033[1m'
DIM=$'\033[2m'

SERVICES=(
    "app-api"
    "tasks-api"
    "mail-api"
    "search-api"
    "private-file-proxy"
    "center-api"
    "entry-api"
    "gmo-api"
    "cloud-sign-api"
    "integration-api"
    "lk-api"
    "ops-api"
    "contract-llm-api"
    "frontend"
    "frontend-server"
    "ops-frontend"
    "ops-frontend-server"
)

get_mode() {
    tmux show-option -qv @c1_dash_mode 2>/dev/null || echo "all"
}

get_pane_status() {
    local window_name="$1"
    local pane_info

    pane_info=$(tmux list-panes -t "${SESSION_NAME}:${window_name}" -F '#{pane_dead}|#{pane_dead_status}|#{pane_pid}|#{pane_current_command}' 2>/dev/null | head -1 || true)

    if [[ -z "$pane_info" ]]; then
        echo "UNKNOWN||0|"
        return
    fi

    local pane_dead pane_dead_status pane_pid pane_cmd
    IFS='|' read -r pane_dead pane_dead_status pane_pid pane_cmd <<< "$pane_info"

    if [[ "$pane_dead" == "1" ]]; then
        echo "DEAD|${pane_dead_status}|${pane_pid}|${pane_cmd}"
    elif [[ "$pane_cmd" == "zsh" || "$pane_cmd" == "bash" || "$pane_cmd" == "sh" ]]; then
        echo "START|0|${pane_pid}|${pane_cmd}"
    else
        echo "OK|0|${pane_pid}|${pane_cmd}"
    fi
}

get_last_log() {
    local window_name="$1"
    local line

    line=$(tmux capture-pane -t "${SESSION_NAME}:${window_name}" -p 2>/dev/null | grep -v '^$' | tail -1 || true)
    line=$(echo "$line" | sed 's/\x1b\[[0-9;]*m//g' | cut -c1-35)
    echo "$line"
}

format_service() {
    local name="$1"
    local status="$2"
    local exit_code="$3"
    local cmd="$4"
    local show_log="$5"
    local log=""

    local icon color
    case "$status" in
        OK)
            icon="●"
            color="$GREEN"
            ;;
        START)
            icon="○"
            color="$YELLOW"
            ;;
        DEAD)
            icon="✗"
            color="$RED"
            ;;
        *)
            icon="?"
            color="$DIM"
            ;;
    esac

    local display_name
    display_name=$(printf "%-13.13s" "$name")

    local status_text
    if [[ "$status" == "DEAD" ]]; then
        status_text="exit:${exit_code}"
    elif [[ "$status" == "START" ]]; then
        status_text="stopped"
    else
        status_text=$(printf "%.8s" "$cmd")
    fi

    if [[ "$show_log" == "true" ]]; then
        log=$(get_last_log "$name")
        if [[ -n "$log" ]]; then
            log=" ${DIM}${log}${NC}"
        fi
    fi

    printf "%b%s%b %-13s %b%-8s%b%s" "$color" "$icon" "$NC" "$display_name" "$DIM" "$status_text" "$NC" "$log"
}

render() {
    local mode="$1"
    local output=""
    local ok_count=0
    local start_count=0
    local dead_count=0

    local statuses=()
    local names=()
    local exit_codes=()
    local cmds=()

    for svc in "${SERVICES[@]}"; do
        local info
        info=$(get_pane_status "$svc")

        local status exit_code pid cmd
        IFS='|' read -r status exit_code pid cmd <<< "$info"

        statuses+=("$status")
        names+=("$svc")
        exit_codes+=("$exit_code")
        cmds+=("$cmd")

        case "$status" in
            OK) ((ok_count++)) ;;
            START) ((start_count++)) ;;
            DEAD) ((dead_count++)) ;;
        esac
    done

    output+="${BOLD}[c1-monitor]${NC} "
    output+="${GREEN}OK:${ok_count}${NC} "
    output+="${YELLOW}START:${start_count}${NC} "
    output+="${RED}DEAD:${dead_count}${NC}  "
    output+="${DIM}[${mode}]${NC}  "
    output+="${DIM}Ctrl+b m: toggle${NC}"
    output+=$'\n\n'

    local display_indices=()
    for i in "${!statuses[@]}"; do
        if [[ "$mode" == "all" ]] || [[ "${statuses[$i]}" != "OK" ]]; then
            display_indices+=("$i")
        fi
    done

    local total=${#display_indices[@]}
    local half=$(( (total + 1) / 2 ))

    for ((row=0; row<half; row++)); do
        local left_idx=${display_indices[$row]:-}
        local right_idx=${display_indices[$((row + half))]:-}

        if [[ -n "$left_idx" ]]; then
            local show_log="false"
            if [[ "$mode" == "bad" ]] || [[ "${statuses[$left_idx]}" != "OK" ]]; then
                show_log="true"
            fi
            output+=$(format_service "${names[$left_idx]}" "${statuses[$left_idx]}" "${exit_codes[$left_idx]}" "${cmds[$left_idx]}" "$show_log")
        fi

        if [[ -n "$right_idx" ]]; then
            output+=" ${DIM}│${NC} "
            local show_log="false"
            if [[ "$mode" == "bad" ]] || [[ "${statuses[$right_idx]}" != "OK" ]]; then
                show_log="true"
            fi
            output+=$(format_service "${names[$right_idx]}" "${statuses[$right_idx]}" "${exit_codes[$right_idx]}" "${cmds[$right_idx]}" "$show_log")
        fi

        output+=$'\n'
    done

    output+=$'\n'
    output+="${DIM}───────────────────────────────────────────────────────────────${NC}"$'\n'
    output+="${DIM}Docker: Window 18 | c1 dash all/bad | c1 logs <service>${NC}"

    echo "$output"
}

main() {
    local prev_output=""

    clear

    while true; do
        local mode
        mode=$(get_mode)

        local output
        output=$(render "$mode")

        if [[ "$output" != "$prev_output" ]]; then
            clear
            echo "$output"
            prev_output="$output"
        fi

        sleep "$REFRESH_INTERVAL"
    done
}

main
