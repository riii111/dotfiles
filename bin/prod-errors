#!/usr/bin/env python3
"""
prod-errors - Production Error Reporting investigation tool.

Usage:
  prod-errors summary [--status OPEN] [--since TIMESTAMP] [--group-by service] [--json]
  prod-errors trace GROUP_ID [--project PROJECT] [--json]

Configuration:
  Set GCP_PROJECT env var (e.g. in ~/.zshrc.local) or use --project flag.
  No default project is hardcoded — GCP_PROJECT is required.
"""

import argparse
import json
import os
import re
import subprocess
import sys
import urllib.error
import urllib.request
from collections import defaultdict
from datetime import datetime, timezone

API_BASE = "https://clouderrorreporting.googleapis.com/v1beta1"


# ---------- main ----------


def main():
    project_from_env = os.environ.get("GCP_PROJECT", "")

    p = argparse.ArgumentParser(
        prog="prod-errors",
        description="Production Error Reporting investigation tool.",
        epilog=(
            "Examples:\n"
            "  prod-errors summary\n"
            "  prod-errors summary --status OPEN,ACKNOWLEDGED\n"
            "  prod-errors summary --group-by service\n"
            "  prod-errors summary --since 2026-03-10T12:00:00Z\n"
            "  prod-errors trace CNrJvq3nnZqKLA\n"
            "  prod-errors --project my-gcp-project summary\n"
            "\n"
            "Configuration:\n"
            "  Set GCP_PROJECT in ~/.zshrc.local (or use --project flag).\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument(
        "--project",
        default=project_from_env,
        help="GCP project ID (env: GCP_PROJECT)"
        + (f" [{project_from_env}]" if project_from_env else " [REQUIRED]"),
    )
    p.add_argument(
        "--json",
        action="store_true",
        default=False,
        help="Output as JSON instead of Markdown",
    )

    sub = p.add_subparsers(dest="command")
    sub.required = True

    s = sub.add_parser("summary", help="List error groups")
    s.add_argument(
        "--status",
        default="OPEN",
        help="Comma-separated status filter (default: OPEN)",
    )
    s.add_argument(
        "--group-by",
        choices=["service"],
        default=None,
        help="Group results by service",
    )
    s.add_argument(
        "--since",
        default=None,
        help="Show errors since timestamp (ISO 8601, e.g. 2026-03-10T12:00:00Z). Useful for post-release monitoring.",
    )

    t = sub.add_parser("trace", help="Deep-dive into an error group")
    t.add_argument("group_id", help="Error group ID from summary output")

    args = p.parse_args()

    if not args.project:
        p.error("--project is required (or set GCP_PROJECT env var in ~/.zshrc.local)")

    {"summary": cmd_summary, "trace": cmd_trace}[args.command](args)


# ---------- summary ----------


def _build_summary_data(filtered, since=None):
    items = []
    for item in filtered:
        g = item["group"]
        entry = {
            "groupId": g.get("groupId", ""),
            "status": g.get("resolutionStatus", ""),
            "message": item.get("representative", {}).get("message", "").split("\n")[0],
            "count": int(item.get("count", "0")),
            "firstSeenTime": item.get("firstSeenTime", ""),
            "lastSeenTime": item.get("lastSeenTime", ""),
            "service": get_service_from_group(item) or None,
        }
        if since:
            first = item.get("firstSeenTime", "")
            entry["isNew"] = first >= since
            entry["isRegressed"] = first < since
        items.append(entry)
    return items


def _build_service_summary_data(filtered, since=None):
    by_service = defaultdict(list)
    for item in filtered:
        svc = get_service_from_group(item) or "(unknown)"
        by_service[svc].append(item)

    services = []
    for svc, items in sorted(
        by_service.items(),
        key=lambda kv: sum(int(g.get("count", "0")) for g in kv[1]),
        reverse=True,
    ):
        top = sorted(items, key=lambda g: int(g.get("count", "0")), reverse=True)[:3]
        entry = {
            "service": svc,
            "groupCount": len(items),
            "totalCount": sum(int(g.get("count", "0")) for g in items),
            "oldestFirstSeen": min(g.get("firstSeenTime", "") for g in items),
            "latestLastSeen": max(g.get("lastSeenTime", "") for g in items),
            "topErrors": [
                g.get("representative", {}).get("message", "").split("\n")[0][:80]
                for g in top
            ],
        }
        if since:
            entry["newCount"] = sum(
                1 for g in items if g.get("firstSeenTime", "") >= since
            )
            entry["regressedCount"] = sum(
                1 for g in items if g.get("firstSeenTime", "") < since
            )
        services.append(entry)
    return services


def cmd_summary(args):
    since = parse_since(args.since) if args.since else None

    token = get_token()
    base_url = build_group_stats_url(args.project)
    groups = api_get_all_pages(base_url, token, "errorGroupStats")

    statuses = {s.strip().upper() for s in args.status.split(",")}
    filtered = [
        g for g in groups if g["group"].get("resolutionStatus", "UNKNOWN") in statuses
    ]

    if since:
        filtered = [g for g in filtered if g.get("lastSeenTime", "") >= since]

    if args.json:
        if args.group_by == "service":
            data = _build_service_summary_data(filtered, since)
        else:
            data = _build_summary_data(filtered, since)
        result = {
            "project": args.project,
            "date": datetime.now(timezone.utc).strftime("%Y-%m-%d"),
            "status": args.status,
            "period": f"since {since}" if since else "30 days",
            "total": len(filtered),
            "groupBy": args.group_by,
        }
        if args.group_by == "service":
            result["services"] = data
        else:
            result["errors"] = data
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return

    if not filtered:
        print(f"No errors with status [{args.status}] in the given time range.")
        return

    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    period = f"since {since}" if since else "30 days"
    print(f"## {args.project} - Error Summary ({today})\n")
    print(f"Status: {args.status} | Period: {period} | Total: {len(filtered)}\n")

    if args.group_by == "service":
        _print_service_summary(filtered, since)
    else:
        _print_flat_summary(filtered, since)


def _print_flat_summary(filtered, since=None):
    header = "| # | Status | groupId | Error | Count | First | Last | Service |"
    if since:
        header = (
            "| # | Status | New? | groupId | Error | Count | First | Last | Service |"
        )
    print(header)
    print(re.sub(r"[^|]", "-", header))

    for i, item in enumerate(filtered, 1):
        g = item["group"]
        gid = g.get("groupId", "")
        status = g.get("resolutionStatus", "")
        count = item.get("count", "0")
        first = item.get("firstSeenTime", "")[:10]
        last = item.get("lastSeenTime", "")[:10]
        msg = item.get("representative", {}).get("message", "").split("\n")[0][:80]
        svc = get_service_from_group(item) or "-"

        if since:
            is_new = item.get("firstSeenTime", "") >= since
            mark = "NEW" if is_new else "REGR"
            print(
                f"| {i} | {status} | {mark} | `{gid}` | {msg} "
                f"| {count} | {first} | {last} | {svc} |"
            )
        else:
            print(
                f"| {i} | {status} | `{gid}` | {msg} "
                f"| {count} | {first} | {last} | {svc} |"
            )

    print("\n> Detail: `prod-errors trace <groupId>`")


def _print_service_summary(filtered, since=None):
    by_service = defaultdict(list)
    for item in filtered:
        svc = get_service_from_group(item) or "(unknown)"
        by_service[svc].append(item)

    sorted_svcs = sorted(
        by_service.items(),
        key=lambda kv: sum(int(g.get("count", "0")) for g in kv[1]),
        reverse=True,
    )

    print(
        "| Service | Groups | Total Count | Oldest First | Latest Last | Top Errors |"
    )
    print(
        "|---------|--------|-------------|--------------|-------------|------------|"
    )

    for svc, items in sorted_svcs:
        group_count = len(items)
        total = sum(int(g.get("count", "0")) for g in items)
        oldest = min(g.get("firstSeenTime", "")[:10] for g in items)
        latest = max(g.get("lastSeenTime", "")[:10] for g in items)
        top = sorted(items, key=lambda g: int(g.get("count", "0")), reverse=True)[:3]
        top_msgs = "; ".join(
            g.get("representative", {}).get("message", "").split("\n")[0][:40]
            for g in top
        )
        print(f"| {svc} | {group_count} | {total} | {oldest} | {latest} | {top_msgs} |")

    print("\n> Flat view: `prod-errors summary`")


# ---------- trace ----------


def cmd_trace(args):
    token = get_token()
    gid = args.group_id
    project = args.project
    as_json = args.json

    base_url = build_group_stats_url(args.project)
    groups = api_get_all_pages(base_url, token, "errorGroupStats")
    target = next(
        (g for g in groups if g["group"].get("groupId") == gid),
        None,
    )
    if not target:
        print(f"Error group {gid} not found.", file=sys.stderr)
        sys.exit(1)

    rep_msg = target.get("representative", {}).get("message", "")
    first_line = rep_msg.split("\n")[0]
    known_service = get_service_from_group(target)

    result = {
        "groupId": gid,
        "message": first_line,
        "count": int(target.get("count", "0")),
        "firstSeenTime": target.get("firstSeenTime", ""),
        "lastSeenTime": target.get("lastSeenTime", ""),
        "service": known_service or None,
    }

    if not as_json:
        print(f"## Error Group: {gid}\n")
        print(f"- Message: {first_line[:120]}")
        print(f"- Count: {target.get('count', '0')}")
        print(f"- First: {target.get('firstSeenTime', '')[:19]}Z")
        print(f"- Last:  {target.get('lastSeenTime', '')[:19]}Z")
        if known_service:
            print(f"- Service (from Error Reporting): {known_service}")

    ev_data = api_get(
        f"{API_BASE}/projects/{project}/events"
        f"?groupId={gid}&timeRange.period=PERIOD_30_DAYS&pageSize=5",
        token,
    )
    events = ev_data.get("errorEvents", [])
    result["recentEvents"] = [
        {
            "eventTime": ev.get("eventTime", ""),
            "service": ev.get("serviceContext", {}).get("service", "unknown"),
        }
        for ev in events
    ]

    if not as_json:
        print(f"\n### Recent Events ({len(events)})\n")
        for ev in events:
            t = ev.get("eventTime", "")[:19]
            s = ev.get("serviceContext", {}).get("service", "unknown")
            print(f"  - {t}Z | {s}")

    # Narrow Cloud Logging search using service from Error Reporting when available
    search = first_line[:80].replace('"', '\\"')
    if known_service:
        filt = (
            f'resource.labels.service_name="{known_service}" "{search}" severity>=ERROR'
        )
    else:
        filt = f'"{search}" severity>=ERROR'

    if not as_json:
        print("\n### Cloud Logging Lookup\n")
        print(f"Filter: `{filt}`\n")

    result["cloudLogging"] = {"filter": filt}

    try:
        logs = logging_read(project, filt, limit=3)
    except LoggingError as e:
        result["cloudLogging"]["error"] = str(e)
        if as_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(f"**Cloud Logging query FAILED**: {e}")
            print("Cannot determine if logs exist. Check auth and filter syntax.")
        return

    if not logs:
        result["cloudLogging"]["matched"] = False
        if as_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print("No matching logs in Cloud Logging (7d window).")
        return

    result["cloudLogging"]["matched"] = True
    entry = logs[0]
    res_labels = entry.get("resource", {}).get("labels", {})
    service = res_labels.get(
        "service_name", res_labels.get("configuration_name", "unknown")
    )
    trace_id = extract_trace_id(entry)
    result["cloudLogging"]["service"] = service
    result["cloudLogging"]["traceId"] = trace_id or None

    if not as_json:
        print(f"- Service: **{service}**")
        print(f"- Trace ID: `{trace_id}`")

    if not trace_id:
        if as_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(
                "\nNo trace_id in log entry. Likely an uncaught exception logged as textPayload."
            )
            print("Tip: search Cloud Logging manually with:")
            print(f'  `resource.labels.service_name="{service}" severity>=ERROR`')
            print("  and look at surrounding logs by timestamp.")
        return

    t_filt = (
        f'resource.labels.service_name="{service}" jsonPayload.trace_id="{trace_id}"'
    )
    try:
        t_logs = logging_read(project, t_filt, limit=30)
        if not t_logs:
            t_filt = (
                f'resource.labels.service_name="{service}" '
                f'trace="projects/{project}/traces/{trace_id}"'
            )
            t_logs = logging_read(project, t_filt, limit=30)
    except LoggingError as e:
        result["lifecycle"] = {"error": str(e)}
        if as_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(f"\n**Cloud Logging trace query FAILED**: {e}")
        return

    if t_logs:
        lifecycle = []
        for tl in reversed(t_logs):
            tjp = tl.get("jsonPayload", {})
            raw = tjp.get("message", "") or tl.get("textPayload", "")
            lifecycle.append(
                {
                    "timestamp": tl.get("timestamp", ""),
                    "severity": tl.get("severity", ""),
                    "logger": tjp.get("logger", ""),
                    "message": strip_ansi(raw).split("\n")[0][:150],
                }
            )
        result["lifecycle"] = lifecycle

        if not as_json:
            print("\n### Request Lifecycle (trace-level match)\n")
            for entry in lifecycle:
                ts = entry["timestamp"][:23]
                sev = entry["severity"]
                logger = entry["logger"]
                tmsg = entry["message"]
                print(f"  [{ts}] {sev:7s} [{logger}] {tmsg}")

    endpoint = None
    error_ts = None
    for tl in t_logs:
        tjp = tl.get("jsonPayload", {})
        raw = tjp.get("message", "") or tl.get("textPayload", "")
        clean = strip_ansi(raw)
        if "500" in clean and (" POST " in clean or " GET " in clean):
            m = re.search(r"- (.+?) in \d+ms", clean)
            if m:
                endpoint = m.group(1).strip()
            error_ts = tl.get("timestamp", "")
            break

    if not endpoint or not error_ts:
        result["retryCheck"] = {"status": "could_not_extract_endpoint"}
        if as_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print("\n### Retry Check\n")
            print("Could not extract endpoint. Manual investigation needed.")
        return

    if not as_json:
        print("\n### Retry Check\n")
        print(f"- Endpoint: `{endpoint}`")
        print(f"- Error at: {error_ts[:23]}Z")

    r_filt = (
        f'resource.labels.service_name="{service}" '
        f'jsonPayload.message:"{endpoint}" '
        f'timestamp>="{error_ts}"'
    )
    try:
        r_logs = logging_read(project, r_filt, limit=30, freshness="1d")
    except LoggingError as e:
        result["retryCheck"] = {"error": str(e)}
        if as_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(f"**Retry check query FAILED**: {e}")
        return

    ok = 0
    fail = 0
    first_ok_ts = None
    for rl in reversed(r_logs):
        rjp = rl.get("jsonPayload", {})
        raw = rjp.get("message", "") or rl.get("textPayload", "")
        rmsg = strip_ansi(raw)
        if "200 OK" in rmsg:
            ok += 1
            if first_ok_ts is None:
                first_ok_ts = rl.get("timestamp", "")[:23]
        elif "500" in rmsg and "Internal Server Error" in rmsg:
            fail += 1

    if ok > 0:
        verdict = "recovered"
    elif fail > 0:
        verdict = "still_failing"
    else:
        verdict = "no_subsequent_requests"

    result["retryCheck"] = {
        "endpoint": endpoint,
        "errorTimestamp": error_ts,
        "successCount": ok,
        "failureCount": fail,
        "firstSuccessTimestamp": first_ok_ts,
        "verdict": verdict,
    }

    if as_json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return

    print(f"- After error: **{ok}** ok / **{fail}** fail")
    if ok > 0:
        print(f"- First success: {first_ok_ts}Z")
        print(
            "- Verdict: **Likely recovered** (⚠ endpoint-level match, not trace-level)"
        )
    elif fail > 0:
        print("- Verdict: **Not recovered** (⚠ endpoint-level match, not trace-level)")
    else:
        print("- Verdict: **Unknown** (no subsequent requests on this endpoint)")


# ---------- helpers ----------


def get_token():
    r = subprocess.run(
        ["gcloud", "auth", "print-access-token"],
        capture_output=True,
        text=True,
    )
    if r.returncode != 0:
        print(f"gcloud auth failed: {r.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return r.stdout.strip()


def api_get(url, token):
    req = urllib.request.Request(url, headers={"Authorization": f"Bearer {token}"})
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")[:200]
        print(f"API error: HTTP {e.code} — {body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"API connection error: {e.reason}", file=sys.stderr)
        sys.exit(1)


def api_get_all_pages(base_url, token, items_key):
    all_items = []
    url = base_url
    while True:
        data = api_get(url, token)
        all_items.extend(data.get(items_key, []))
        next_token = data.get("nextPageToken")
        if not next_token:
            break
        sep = "&" if "?" in base_url else "?"
        url = f"{base_url}{sep}pageToken={next_token}"
    return all_items


class LoggingError(Exception):
    pass


def logging_read(project, filt, limit=10, freshness="7d"):
    """Raises LoggingError on query failure, returns [] on empty results."""
    r = subprocess.run(
        [
            "gcloud",
            "logging",
            "read",
            filt,
            f"--project={project}",
            f"--limit={limit}",
            "--format=json",
            f"--freshness={freshness}",
        ],
        capture_output=True,
        text=True,
        timeout=120,
    )
    if r.returncode != 0:
        raise LoggingError(r.stderr.strip()[:200])
    if not r.stdout.strip():
        return []
    return json.loads(r.stdout)


def strip_ansi(text):
    return re.sub(r"\x1b\[[0-9;]*m", "", text)


def extract_trace_id(entry):
    """trace_id is stored in different locations depending on the service."""
    jp = entry.get("jsonPayload", {})
    tid = jp.get("trace_id", "")
    if tid:
        return tid
    trace_field = entry.get("trace", "")
    if trace_field and "/traces/" in trace_field:
        return trace_field.split("/traces/")[-1]
    return ""


def get_service_from_group(item):
    svcs = item.get("affectedServices", [])
    for s in svcs:
        name = s.get("service", "")
        if name:
            return name
    return ""


def parse_since(value):
    """Normalize --since to UTC ISO 8601 string for safe comparison with API timestamps."""
    for fmt in ("%Y-%m-%dT%H:%M:%SZ", "%Y-%m-%dT%H:%M:%S%z", "%Y-%m-%dT%H:%M:%S.%f%z"):
        try:
            dt = datetime.strptime(value, fmt)
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=timezone.utc)
            return dt.astimezone(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ")
        except ValueError:
            continue
    # Bare date like 2026-03-10
    try:
        dt = datetime.strptime(value, "%Y-%m-%d").replace(tzinfo=timezone.utc)
        return dt.strftime("%Y-%m-%dT%H:%M:%S.%fZ")
    except ValueError:
        pass
    print(f"Cannot parse --since value: {value}", file=sys.stderr)
    sys.exit(1)


def build_group_stats_url(project):
    # API doesn't support custom time ranges; --since is filtered locally
    return (
        f"{API_BASE}/projects/{project}/groupStats"
        f"?timeRange.period=PERIOD_30_DAYS&pageSize=100"
    )


if __name__ == "__main__":
    main()
