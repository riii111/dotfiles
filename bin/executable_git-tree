#!/usr/bin/env python3
"""Display local branch hierarchy as a tree, rooted at main/master."""

import os
import subprocess
import sys
from functools import lru_cache


# ANSI color helpers — disabled when piped or NO_COLOR is set
_use_color = sys.stdout.isatty() and "NO_COLOR" not in os.environ
GREEN = "\033[1;32m" if _use_color else ""
CYAN = "\033[36m" if _use_color else ""
RESET = "\033[0m" if _use_color else ""


@lru_cache(maxsize=None)
def _run_cached(cmd):
    return (
        subprocess.check_output(list(cmd), stderr=subprocess.DEVNULL).decode().strip()
    )


@lru_cache(maxsize=None)
def _check_cached(cmd):
    return (
        subprocess.run(
            list(cmd),
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        ).returncode
        == 0
    )


def run(cmd):
    return _run_cached(tuple(cmd))


def try_run(cmd):
    try:
        return run(cmd)
    except subprocess.CalledProcessError:
        return None


def count_commits(start, end, first_parent=False):
    cmd = ["git", "rev-list", "--count"]
    if first_parent:
        cmd.append("--first-parent")
    cmd.append(f"{start}..{end}")
    output = try_run(cmd)
    return int(output) if output is not None else None


def is_ancestor(ancestor, descendant):
    return _check_cached(("git", "merge-base", "--is-ancestor", ancestor, descendant))


def branch_birth_time(branch):
    output = try_run(["git", "reflog", "show", "--format=%ct", branch])
    if not output:
        return None
    return int(output.splitlines()[-1])


def main():
    # Detect default branch
    for candidate in ("main", "master"):
        try:
            run(["git", "rev-parse", "--verify", candidate])
            root = candidate
            break
        except subprocess.CalledProcessError:
            continue
    else:
        print("error: neither main nor master branch found", file=sys.stderr)
        sys.exit(1)

    branches = run(["git", "branch", "--format=%(refname:short)"]).split("\n")
    branches = [b for b in branches if b and b != root]

    current = run(["git", "branch", "--show-current"])
    birth_times = {branch: branch_birth_time(branch) for branch in [root] + branches}
    root_distances = {branch: count_commits(root, branch) or 0 for branch in branches}

    # Gather worktree info: branch -> worktree path
    worktrees = {}
    try:
        wt_output = run(["git", "worktree", "list", "--porcelain"])
        wt_path = None
        for line in wt_output.split("\n"):
            if line.startswith("worktree "):
                wt_path = line[len("worktree ") :]
            elif line.startswith("branch refs/heads/"):
                branch_name = line[len("branch refs/heads/") :]
                if wt_path:
                    worktrees[branch_name] = wt_path
    except subprocess.CalledProcessError:
        pass

    def parent_candidate(candidate, branch):
        branch_point = try_run(["git", "merge-base", "--fork-point", candidate, branch])
        mode = "fork-point"

        if branch_point is None:
            tip = try_run(["git", "rev-parse", candidate])
            merge_base = try_run(["git", "merge-base", candidate, branch])
            if tip is None or merge_base != tip:
                return None
            branch_point = tip
            mode = "ancestor-tip"

        distance = count_commits(branch_point, branch)
        if distance is None or distance <= 0:
            return None

        first_parent_distance = count_commits(branch_point, branch, first_parent=True)
        if first_parent_distance is None:
            return None

        candidate_distance = count_commits(branch_point, candidate, first_parent=True)
        if candidate_distance is None:
            return None

        branch_depth = count_commits(root, branch_point) or 0
        return {
            "mode": mode,
            "distance": distance,
            "first_parent_distance": first_parent_distance,
            "candidate_distance": candidate_distance,
            "branch_depth": branch_depth,
        }

    # Build parent-child tree by finding the most likely branch point
    tree = {root: []}
    parents = {}
    commit_counts = {}
    mode_rank = {"fork-point": 0, "ancestor-tip": 1}
    ordered_branches = sorted(
        branches,
        key=lambda branch: (
            birth_times[branch] is None,
            birth_times[branch] or float("inf"),
            root_distances[branch],
            branch,
        ),
    )
    placed_branches = []

    for b in ordered_branches:
        candidates = []
        for cand in [root] + placed_branches:
            if is_ancestor(b, cand):
                continue
            candidate = parent_candidate(cand, b)
            if candidate is not None:
                candidates.append((cand, candidate))

        if candidates:
            best_parent, best = min(
                candidates,
                key=lambda item: (
                    mode_rank[item[1]["mode"]],
                    item[1]["first_parent_distance"],
                    item[1]["candidate_distance"],
                    item[1]["distance"],
                    -item[1]["branch_depth"],
                    item[0],
                ),
            )
            commit_counts[b] = best["distance"]
        else:
            best_parent = root
            commit_counts[b] = count_commits(root, b) or 0

        parents[b] = best_parent
        tree.setdefault(best_parent, []).append(b)
        placed_branches.append(b)

    def colorize(text, color):
        return f"{color}{text}{RESET}"

    def format_node(node, is_root=False):
        is_current = node == current
        is_worktree = node in worktrees and not is_current

        parts = [node]
        if not is_root:
            parts.append(f"(+{commit_counts[node]})")
        if is_worktree:
            wt_path = worktrees[node]
            wt_name = wt_path.rsplit("/", 1)[-1]
            parts.append(f"● {wt_name}")
        if is_current:
            parts.append("★")

        label = " ".join(parts)
        if is_current:
            return colorize(label, GREEN)
        elif is_worktree:
            return colorize(label, CYAN)
        return label

    def print_tree(node, prefix="", is_last=True, is_root=True):
        if is_root:
            line = f"  {format_node(node, is_root=True)}"
        else:
            marker = "└── " if is_last else "├── "
            line = f"  {prefix}{marker}{format_node(node)}"
        print(line)
        children = tree.get(node, [])
        for i, child in enumerate(children):
            last = i == len(children) - 1
            new_prefix = prefix + ("    " if is_last else "│   ")
            if is_root:
                new_prefix = ""
            print_tree(child, new_prefix, last, False)

    print()
    print_tree(root)
    print()


if __name__ == "__main__":
    main()
