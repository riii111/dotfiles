#!/usr/bin/env python3

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path


USE_COLOR = sys.stdout.isatty() and "NO_COLOR" not in os.environ
GREEN = "\033[32m" if USE_COLOR else ""
YELLOW = "\033[33m" if USE_COLOR else ""
RESET = "\033[0m" if USE_COLOR else ""

REASON_PRUNABLE = "prunable"
REASON_GONE_BRANCH_WORKTREE = "gone branch worktree"
REASON_MERGED_BRANCH_WORKTREE = "merged branch worktree"
REASON_CLOSED_PR_WORKTREE = "closed pr worktree"


def style(color, text):
    return f"{color}{text}{RESET}" if color else text


def git_output(*args, cwd=None):
    return subprocess.run(
        ["git", *args],
        text=True,
        cwd=cwd,
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    ).stdout.strip()


def git_run(*args, cwd=None):
    return subprocess.run(
        ["git", *args],
        text=True,
        cwd=cwd,
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def branch_details():
    # Full refname to match `git worktree list --porcelain` branch lines.
    output = git_output(
        "for-each-ref",
        "--format=%(refname)\t%(upstream:short)\t%(upstream:track)",
        "refs/heads",
    )
    details = {}
    for line in output.splitlines():
        if not line:
            continue
        refname, _, rest = line.partition("\t")
        upstream, _, track = rest.partition("\t")
        details[refname] = {
            "upstream": upstream,
            "track": track,
        }
    return details


def worktrees():
    output = git_output("worktree", "list", "--porcelain")
    entries = []
    entry = None

    for line in output.splitlines():
        if line.startswith("worktree "):
            if entry is not None:
                entries.append(entry)
            entry = {
                "path": line[len("worktree ") :],
                "branch": None,
                "detached": False,
                "locked": False,
                "prunable": False,
            }
        elif entry is None:
            continue
        elif line.startswith("branch "):
            entry["branch"] = line[len("branch ") :]
        elif line == "detached":
            entry["detached"] = True
        elif line.startswith("locked"):
            entry["locked"] = True
        elif line.startswith("prunable"):
            entry["prunable"] = True

    if entry is not None:
        entries.append(entry)

    return entries


def is_dirty(path):
    return bool(git_output("status", "--porcelain", cwd=path))


def parse_args(argv):
    parser = argparse.ArgumentParser(prog="git prune-gone-wt")
    parser.add_argument("-n", "--dry-run", action="store_true")
    parser.add_argument("--no-fetch", action="store_true")
    return parser.parse_args(argv)


def worktree_name(entry):
    branch = entry["branch"]
    if branch:
        return branch.removeprefix("refs/heads/")
    return Path(entry["path"]).name


def managed_worktree_roots(repo_root):
    return (
        repo_root / ".claude" / "worktrees",
        repo_root / ".codex" / "worktrees",
    )


def is_managed_worktree_path(path, repo_root):
    path = path.resolve()
    repo_root = repo_root.resolve()

    for managed_root in managed_worktree_roots(repo_root):
        try:
            path.relative_to(managed_root)
            return True
        except ValueError:
            continue
    return False


def default_branch():
    for candidate in ("main", "master"):
        if git_run("show-ref", "--verify", f"refs/heads/{candidate}").returncode == 0:
            return candidate, candidate

    try:
        origin_head = git_output("symbolic-ref", "refs/remotes/origin/HEAD")
        prefix = "refs/remotes/origin/"
        if origin_head.startswith(prefix):
            remote_branch = origin_head[len(prefix) :]
            if (
                git_run(
                    "show-ref", "--verify", f"refs/remotes/origin/{remote_branch}"
                ).returncode
                == 0
            ):
                return None, f"origin/{remote_branch}"
    except subprocess.CalledProcessError:
        pass

    current = git_output("branch", "--show-current")
    if current:
        return current, current

    raise subprocess.CalledProcessError(
        returncode=1,
        cmd=["git", "branch", "--show-current"],
    )


def is_merged_into(base_ref, branch):
    result = git_run("merge-base", "--is-ancestor", branch, base_ref)
    return result.returncode == 0


def extract_review_pr_number(path, repo_root):
    path = path.resolve()
    repo_root = repo_root.resolve()
    pattern = rf"^{re.escape(repo_root.name)}-pr-(\d+)$"
    if path.parent != repo_root.parent:
        return None
    match = re.match(pattern, path.name)
    if match is None:
        return None
    return int(match.group(1))


def parse_origin_repo():
    url = git_output("remote", "get-url", "origin")
    ssh_match = re.match(r"^git@[^:]*github\.com[^:]*:(.+)$", url)
    if ssh_match is not None:
        path = ssh_match.group(1)
    elif "github.com/" in url:
        path = url.split("github.com/", 1)[1]
    else:
        return None

    if path.endswith(".git"):
        path = path[:-4]
    if "/" not in path:
        return None
    owner, repo = path.split("/", 1)
    return owner, repo


def gh_auth_users():
    result = subprocess.run(
        ["gh", "auth", "status", "--json", "hosts"],
        text=True,
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        return []

    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        return []

    users = []
    for account in payload.get("hosts", {}).get("github.com", []):
        login = account.get("login")
        if login:
            users.append(login)
    return users


def pr_state_override(pr_number):
    raw = os.environ.get("PRUNE_GONE_WT_PR_STATES", "").strip()
    if not raw:
        return None

    for item in raw.split(","):
        number, _, state = item.partition(":")
        if number.strip() == str(pr_number) and state.strip():
            return state.strip().upper()
    return None


def graphql_pr_states_query(owner, repo, pr_numbers):
    owner = json.dumps(owner)
    repo = json.dumps(repo)
    query_lines = [
        "query {",
        f"  repository(owner: {owner}, name: {repo}) {{",
    ]
    for pr_number in pr_numbers:
        query_lines.append(
            f"    pr{pr_number}: pullRequest(number: {pr_number}) {{ state }}"
        )
    query_lines.extend(["  }", "}"])
    return "\n".join(query_lines)


def pr_states(pr_numbers):
    states = {}
    remaining = []
    for pr_number in sorted(set(pr_numbers)):
        override = pr_state_override(pr_number)
        if override is not None:
            states[pr_number] = override
        else:
            remaining.append(pr_number)

    if not remaining:
        return states

    repo = parse_origin_repo()
    if repo is None:
        print(
            "Warning: could not determine GitHub origin repo for PR state lookup",
            file=sys.stderr,
        )
        return states
    owner, name = repo
    query = graphql_pr_states_query(owner, name, remaining)
    query_succeeded = False

    for user in gh_auth_users():
        token = subprocess.run(
            ["gh", "auth", "token", "--hostname", "github.com", "--user", user],
            text=True,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        if token.returncode != 0:
            continue

        env = os.environ.copy()
        env["GH_TOKEN"] = token.stdout.strip()
        result = subprocess.run(
            ["gh", "api", "graphql", "-f", f"query={query}"],
            text=True,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            env=env,
        )
        if result.returncode == 0:
            try:
                payload = json.loads(result.stdout)
            except json.JSONDecodeError:
                continue
            repository = payload.get("data", {}).get("repository", {})
            query_succeeded = True
            for pr_number in remaining:
                state = repository.get(f"pr{pr_number}", {}).get("state")
                if state:
                    states[pr_number] = state.upper()
            return states

    if not query_succeeded:
        print("Warning: could not fetch PR states from GitHub", file=sys.stderr)
    return states


def review_pr_numbers_by_path(entries, repo_root):
    pr_numbers_by_path = {}
    for entry in entries:
        if not entry["detached"]:
            continue
        path = str(Path(entry["path"]).resolve())
        pr_number = extract_review_pr_number(Path(path), repo_root)
        if pr_number is not None:
            pr_numbers_by_path[path] = pr_number
    return pr_numbers_by_path


def candidate_reason(
    entry,
    path,
    review_pr_number,
    repo_root,
    branch_info,
    base_branch,
    base_ref,
    review_pr_states,
):
    branch = entry["branch"]
    info = branch_info.get(branch or "", {"upstream": "", "track": ""})

    if entry["prunable"]:
        return REASON_PRUNABLE

    if bool(branch) and info["track"] == "[gone]":
        return REASON_GONE_BRANCH_WORKTREE

    if bool(branch) and is_managed_worktree_path(path, repo_root):
        branch_name = branch.removeprefix("refs/heads/")
        is_default_branch = base_branch is not None and branch_name == base_branch
        if (
            not info["upstream"]
            and not is_default_branch
            and is_merged_into(base_ref, branch_name)
        ):
            return REASON_MERGED_BRANCH_WORKTREE

    if review_pr_number is not None:
        review_pr_state = review_pr_states.get(review_pr_number)
        if review_pr_state in {"CLOSED", "MERGED"}:
            return REASON_CLOSED_PR_WORKTREE

    return None


def skip_reason_for_non_candidate(review_pr_number, review_pr_states):
    if review_pr_number is None:
        return None

    review_pr_state = review_pr_states.get(review_pr_number)
    if review_pr_state == "OPEN":
        return "open pr"
    if review_pr_state is None:
        return "unknown pr"
    return None


def main(argv):
    try:
        args = parse_args(argv)
        if not args.no_fetch:
            subprocess.run(
                ["git", "fetch", "--prune", "--quiet"],
                check=True,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )

        current = Path(
            git_output("rev-parse", "--path-format=absolute", "--show-toplevel")
        ).resolve()
        primary = (
            Path(git_output("rev-parse", "--path-format=absolute", "--git-common-dir"))
            .resolve()
            .parent
        )
        repo_root = primary
        entries = worktrees()
        branch_info = branch_details()
        base_branch, base_ref = default_branch()
        review_pr_numbers = review_pr_numbers_by_path(entries, repo_root)
        review_pr_states = pr_states(review_pr_numbers.values())

        lines = []
        removed = 0
        skipped = 0
        exit_code = 0
        prunable_names = []
        should_show_branch_hint = False

        for entry in entries:
            name = worktree_name(entry)
            path = Path(entry["path"]).resolve()
            review_pr_number = review_pr_numbers.get(str(path))
            reason = candidate_reason(
                entry,
                path,
                review_pr_number,
                repo_root,
                branch_info,
                base_branch,
                base_ref,
                review_pr_states,
            )
            if reason is None:
                skip_reason = skip_reason_for_non_candidate(
                    review_pr_number, review_pr_states
                )
                if skip_reason is not None:
                    lines.append(style(YELLOW, f"Skipped ({skip_reason}): {name}"))
                    skipped += 1
                continue
            if reason in {
                REASON_GONE_BRANCH_WORKTREE,
                REASON_MERGED_BRANCH_WORKTREE,
            } or (
                # Pruning stale worktree metadata still leaves the local branch behind.
                reason == REASON_PRUNABLE and bool(entry["branch"])
            ):
                should_show_branch_hint = True

            if path == current:
                lines.append(style(YELLOW, f"Skipped (current): {name}"))
                skipped += 1
                continue
            if path == primary:
                lines.append(style(YELLOW, f"Skipped (primary): {name}"))
                skipped += 1
                continue
            if entry["locked"]:
                lines.append(style(YELLOW, f"Skipped (locked): {name}"))
                skipped += 1
                continue
            if reason == REASON_PRUNABLE:
                if args.dry_run:
                    lines.append(style(GREEN, f"Would prune (worktree): {name}"))
                    removed += 1
                else:
                    # `git worktree prune` respects locks, so skipped locked entries remain safe.
                    prunable_names.append(name)
                continue
            if is_dirty(path):
                lines.append(style(YELLOW, f"Skipped (dirty): {name}"))
                skipped += 1
                continue

            if args.dry_run:
                lines.append(style(GREEN, f"Would remove ({reason}): {name}"))
                removed += 1
                continue

            result = git_run("worktree", "remove", str(path))
            if result.returncode == 0:
                lines.append(style(GREEN, f"Removed ({reason}): {name}"))
                removed += 1
            else:
                lines.append(style(YELLOW, f"Skipped (remove failed): {name}"))
                skipped += 1
                exit_code = 1

        if prunable_names:
            result = git_run("worktree", "prune", "--expire", "now")
            if result.returncode == 0:
                for name in prunable_names:
                    lines.append(style(GREEN, f"Pruned (worktree): {name}"))
                    removed += 1
            else:
                for name in prunable_names:
                    lines.append(style(YELLOW, f"Skipped (prune failed): {name}"))
                    skipped += 1
                exit_code = 1

        if not lines:
            print("No gone worktrees found")
            return 0

        print("\n".join(lines))
        if args.dry_run:
            print(f"Summary: {removed} would remove, {skipped} skipped")
        else:
            print(f"Summary: {removed} removed, {skipped} skipped")
        if should_show_branch_hint:
            print("Hint: branches still exist. Run `git prune-gone-br` to remove them.")

        return exit_code
    except subprocess.CalledProcessError as exc:
        cmd = " ".join(str(part) for part in exc.cmd)
        print(f"Error: `{cmd}` failed (exit {exc.returncode})", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr.strip(), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
