#!/usr/bin/env python3

import argparse
import os
import subprocess
import sys


USE_COLOR = sys.stdout.isatty() and "NO_COLOR" not in os.environ
GREEN = "\033[32m" if USE_COLOR else ""
YELLOW = "\033[33m" if USE_COLOR else ""
RESET = "\033[0m" if USE_COLOR else ""


def style(color, text):
    return f"{color}{text}{RESET}" if color else text


def git_output(*args):
    return subprocess.run(
        ["git", *args],
        text=True,
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    ).stdout.strip()


def git_run(*args):
    return subprocess.run(
        ["git", *args],
        text=True,
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def worktree_branches():
    output = git_output("worktree", "list", "--porcelain")
    branches = set()
    prefix = "branch refs/heads/"
    for line in output.splitlines():
        if line.startswith(prefix):
            branches.add(line[len(prefix) :])
    return branches


def gone_branches():
    output = git_output(
        "for-each-ref",
        "--format=%(refname:short)\t%(upstream:track)",
        "refs/heads",
    )
    for line in output.splitlines():
        if not line:
            continue
        branch, _, track = line.partition("\t")
        if track == "[gone]":
            yield branch


def parse_args(argv):
    parser = argparse.ArgumentParser(prog="git prune-gone-br")
    parser.add_argument("-n", "--dry-run", action="store_true")
    return parser.parse_args(argv)


def main(argv):
    try:
        args = parse_args(argv)
        subprocess.run(
            ["git", "fetch", "--prune", "--quiet"],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )

        active_worktrees = worktree_branches()
        lines = []
        removed = 0
        skipped = 0
        exit_code = 0

        for branch in gone_branches():
            if branch in active_worktrees:
                lines.append(style(YELLOW, f"Skipped (worktree): {branch}"))
                skipped += 1
                continue

            if args.dry_run:
                lines.append(style(GREEN, f"Would remove (branch): {branch}"))
                removed += 1
                continue

            result = git_run("branch", "-D", branch)
            if result.returncode == 0:
                lines.append(style(GREEN, f"Removed (branch): {branch}"))
                removed += 1
            else:
                lines.append(style(YELLOW, f"Skipped (delete failed): {branch}"))
                skipped += 1
                exit_code = 1

        if not lines:
            print("No gone branches found")
            return 0

        print("\n".join(lines))
        if args.dry_run:
            print(f"Summary: {removed} would remove, {skipped} skipped")
        else:
            print(f"Summary: {removed} removed, {skipped} skipped")

        return exit_code
    except subprocess.CalledProcessError as exc:
        cmd = " ".join(str(part) for part in exc.cmd)
        print(f"Error: `{cmd}` failed (exit {exc.returncode})", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr.strip(), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
