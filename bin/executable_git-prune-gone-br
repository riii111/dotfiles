#!/usr/bin/env python3

import argparse
import os
import subprocess
import sys


USE_COLOR = sys.stdout.isatty() and "NO_COLOR" not in os.environ
GREEN = "\033[32m" if USE_COLOR else ""
YELLOW = "\033[33m" if USE_COLOR else ""
RESET = "\033[0m" if USE_COLOR else ""


def style(color, text):
    return f"{color}{text}{RESET}" if color else text


def git_output(*args):
    return subprocess.run(
        ["git", *args],
        text=True,
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    ).stdout.strip()


def git_run(*args):
    return subprocess.run(
        ["git", *args],
        text=True,
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def worktree_branches():
    output = git_output("worktree", "list", "--porcelain")
    branches = set()
    prefix = "branch refs/heads/"
    for line in output.splitlines():
        if line.startswith(prefix):
            branches.add(line[len(prefix) :])
    return branches


def branch_details():
    output = git_output(
        "for-each-ref",
        "--format=%(refname:short)\t%(upstream:short)\t%(upstream:track)",
        "refs/heads",
    )
    for line in output.splitlines():
        if not line:
            continue
        branch, _, rest = line.partition("\t")
        upstream, _, track = rest.partition("\t")
        yield {
            "branch": branch,
            "upstream": upstream,
            "track": track,
        }


def default_branch():
    for candidate in ("main", "master"):
        if git_run("show-ref", "--verify", f"refs/heads/{candidate}").returncode == 0:
            return candidate, candidate

    current = git_output("branch", "--show-current")
    if current:
        return current, current

    try:
        origin_head = git_output("symbolic-ref", "refs/remotes/origin/HEAD")
        prefix = "refs/remotes/origin/"
        if origin_head.startswith(prefix):
            remote_branch = origin_head[len(prefix) :]
            if (
                git_run(
                    "show-ref", "--verify", f"refs/remotes/origin/{remote_branch}"
                ).returncode
                == 0
            ):
                return None, f"origin/{remote_branch}"
    except subprocess.CalledProcessError:
        pass

    raise subprocess.CalledProcessError(
        returncode=1,
        cmd=["git", "branch", "--show-current"],
    )


def is_merged_into(base_ref, branch):
    result = git_run("merge-base", "--is-ancestor", branch, base_ref)
    return result.returncode == 0


def parse_args(argv):
    parser = argparse.ArgumentParser(prog="git prune-gone-br")
    parser.add_argument("-n", "--dry-run", action="store_true")
    parser.add_argument("--no-fetch", action="store_true")
    return parser.parse_args(argv)


def main(argv):
    try:
        args = parse_args(argv)
        if not args.no_fetch:
            subprocess.run(
                ["git", "fetch", "--prune", "--quiet"],
                check=True,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )

        active_worktrees = worktree_branches()
        base_branch, base_ref = default_branch()
        lines = []
        removed = 0
        skipped = 0
        exit_code = 0

        for detail in branch_details():
            branch = detail["branch"]
            if base_branch is not None and branch == base_branch:
                continue
            if branch in active_worktrees:
                lines.append(style(YELLOW, f"Skipped (worktree): {branch}"))
                skipped += 1
                continue

            reason = None
            delete_args = ("branch", "-D", branch)
            if detail["track"] == "[gone]":
                reason = "gone branch"
            elif not detail["upstream"] and is_merged_into(base_ref, branch):
                reason = "merged branch"
                delete_args = ("branch", "-d", branch)
            elif branch.startswith("_slot-") and not detail["upstream"]:
                reason = "orphan slot branch"

            if reason is None:
                continue

            if args.dry_run:
                lines.append(style(GREEN, f"Would remove ({reason}): {branch}"))
                removed += 1
                continue

            result = git_run(*delete_args)
            if result.returncode == 0:
                lines.append(style(GREEN, f"Removed ({reason}): {branch}"))
                removed += 1
            else:
                lines.append(style(YELLOW, f"Skipped (delete failed): {branch}"))
                skipped += 1
                exit_code = 1

        if not lines:
            print("No stale branches found")
            return 0

        print("\n".join(lines))
        if args.dry_run:
            print(f"Summary: {removed} would remove, {skipped} skipped")
        else:
            print(f"Summary: {removed} removed, {skipped} skipped")

        return exit_code
    except subprocess.CalledProcessError as exc:
        cmd = " ".join(str(part) for part in exc.cmd)
        print(f"Error: `{cmd}` failed (exit {exc.returncode})", file=sys.stderr)
        if exc.stderr:
            print(exc.stderr.strip(), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
