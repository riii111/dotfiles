#!/usr/bin/env python3

import subprocess
import sys


def git_output(*args):
    return subprocess.check_output(["git", *args], text=True).strip()


def git_run(*args):
    return subprocess.run(
        ["git", *args],
        text=True,
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def worktree_branches():
    output = git_output("worktree", "list", "--porcelain")
    branches = set()
    prefix = "branch refs/heads/"
    for line in output.splitlines():
        if line.startswith(prefix):
            branches.add(line[len(prefix) :])
    return branches


def gone_branches():
    output = git_output(
        "for-each-ref",
        "--format=%(refname:short)\t%(upstream:track)",
        "refs/heads",
    )
    for line in output.splitlines():
        if not line:
            continue
        branch, _, track = line.partition("\t")
        if track == "[gone]":
            yield branch


def main(argv):
    if argv:
        print("Usage: git prune-gone-br", file=sys.stderr)
        return 1

    subprocess.run(["git", "fetch", "--prune", "--quiet"], check=True)

    active_worktrees = worktree_branches()
    matched = False
    exit_code = 0

    for branch in gone_branches():
        matched = True
        if branch in active_worktrees:
            print(f"Skipped (worktree): {branch}")
            continue

        result = git_run("branch", "-D", branch)
        if result.returncode == 0:
            print(f"Removed (branch): {branch}")
        else:
            print(f"Skipped (delete failed): {branch}")
            exit_code = 1

    if not matched:
        print("No gone branches found")

    return exit_code


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
