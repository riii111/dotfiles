#!/usr/bin/env bash
#
# wt-init - Create reusable git worktree slots with symlinked excluded files.
# Slots are named w1, w2, ... and auto-increment from the highest existing slot.
#
# Usage: wt-init <count>
#   count: number of worktree slots to create
#
# Examples:
#   wt-init 3     # creates w1, w2, w3
#   wt-init 1     # if w1-w3 exist, creates w4

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "Error: not in a git repo" >&2; exit 1
}
cd "$repo_root"

count="${1:-}"
if [[ -z "$count" || ! "$count" =~ ^[0-9]+$ || "$count" -lt 1 ]]; then
  echo "Usage: wt-init <count>" >&2
  exit 1
fi

worktree_dir=".worktrees"
exclude_file=".git/info/exclude"

# Ensure .worktrees/ is in exclude
if [[ ! -f "$exclude_file" ]]; then
  mkdir -p "$(dirname "$exclude_file")"
  touch "$exclude_file"
fi
if ! grep -qx '.worktrees/' "$exclude_file"; then
  echo '.worktrees/' >> "$exclude_file"
  echo "Added .worktrees/ to $exclude_file"
fi

# Find highest existing slot number
max=0
for d in "$worktree_dir"/w[0-9]*; do
  [[ -d "$d" ]] || continue
  num="${d##*/w}"
  if [[ "$num" =~ ^[0-9]+$ ]] && [[ "$num" -gt "$max" ]]; then max=$num; fi
done

# Parse exclude file for symlink candidates
candidates=()
if [[ -f "$exclude_file" ]]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    path="$line"
    path="${path#/}"
    path="${path%/\*\*}"
    path="${path%/}"
    [[ "$path" == *"*"* ]] && continue
    [[ "$path" == ".worktrees" ]] && continue
    [[ "$path" == *".."* ]] && continue
    [[ -e "$repo_root/$path" ]] && candidates+=("$path")
  done < "$exclude_file"
fi

# Select symlink targets via fzf (skip if fzf is not available)
selected=()
if [[ ${#candidates[@]} -gt 0 ]]; then
  if command -v fzf >/dev/null 2>&1; then
    echo "Select files/dirs to symlink into worktrees (TAB to select, Enter to confirm):"
    fzf_exit=0
    while IFS= read -r item; do
      selected+=("$item")
    done < <(printf '%s\n' "${candidates[@]}" | fzf --multi --prompt="symlink> ") || fzf_exit=$?
    if [[ "$fzf_exit" -ne 0 ]] && [[ ${#selected[@]} -eq 0 ]]; then
      echo "fzf selection cancelled."
    fi
  else
    echo "Warning: fzf not found. Skipping symlink selection." >&2
  fi
fi

if [[ ${#selected[@]} -eq 0 ]]; then
  echo "No symlink targets selected. Creating worktrees without symlinks."
fi

# Resolve default branch: origin/HEAD -> current branch -> main/master -> error
resolve_default_branch() {
  local branch
  branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@') && [[ -n "$branch" ]] && echo "$branch" && return
  branch=$(git symbolic-ref --short HEAD 2>/dev/null) && [[ -n "$branch" ]] && echo "$branch" && return
  for candidate in main master; do
    if git show-ref --verify --quiet "refs/heads/$candidate"; then
      echo "$candidate" && return
    fi
  done
  echo "Error: cannot determine default branch" >&2
  return 1
}
default_branch=$(resolve_default_branch)

# Rollback helper: remove a partially created slot
rollback_slot() {
  local slot_path="$1" slot_branch="$2"
  echo "  Rolling back $slot_path..." >&2
  git worktree remove "$slot_path" --force 2>/dev/null || rm -rf "$slot_path"
  if git show-ref --verify --quiet "refs/heads/$slot_branch"; then
    git branch -D "$slot_branch" 2>/dev/null || true
  fi
}

# Create worktree slots
mkdir -p "$worktree_dir"
for ((i=1; i<=count; i++)); do
  slot=$((max + i))
  name="w${slot}"
  path="$worktree_dir/$name"

  if [[ -d "$path" ]]; then
    echo "Skip: $name already exists"
    continue
  fi

  echo "Creating $name..."
  git worktree prune
  if git show-ref --verify --quiet "refs/heads/_slot-${name}"; then
    echo "  Warning: stale branch _slot-${name} found, removing." >&2
    git branch -D "_slot-${name}" 2>/dev/null || echo "  Warning: failed to delete _slot-${name}" >&2
  fi

  if ! git worktree add "$path" -b "_slot-${name}" "$default_branch"; then
    echo "  Error: failed to create worktree $name" >&2
    rollback_slot "$path" "_slot-${name}"
    continue
  fi

  # Create symlinks (with rollback on failure)
  link_failed=0
  for item in "${selected[@]+${selected[@]}}"; do
    src="$repo_root/$item"
    dst="$path/$item"
    if ! mkdir -p "$(dirname "$dst")"; then
      link_failed=1; break
    fi
    [[ -e "$dst" && ! -L "$dst" ]] && rm -rf "$dst"
    if ! ln -sfn "$src" "$dst"; then
      link_failed=1; break
    fi
    echo "  Linked: $item"
  done

  if [[ "$link_failed" -ne 0 ]]; then
    echo "  Error: symlink creation failed for $name, rolling back." >&2
    rollback_slot "$path" "_slot-${name}"
    continue
  fi

  echo "  Done: $path (branch: _slot-${name})"
done

echo ""
echo "Slots ready! Usage:"
echo "  cd $worktree_dir/w$((max + 1))"
echo "  git checkout -b feature/your-branch"
echo "  cc-impl w$((max + 1))"
