      "Read",
      "Glob",
      "Grep",
      "Agent",
      "WebSearch",
      "WebFetch",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "mcp__plugin_Notion_notion__notion-fetch",
      "Skill(codex-2nd)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git rebase*)",
      "Bash(git fetch*)",
      "Bash(git pull:*)",
      "Bash(git stash*)",
      "Bash(git worktree*)",
      "Bash(git rev-parse*)",
      "Bash(git config*)",
      "Bash(git remote*)",
      "Bash(git cherry-pick*)",
      "Bash(git tag*)",
      "Bash(git mv:*)",
      "Bash(git merge-tree:*)",
      "Bash(gh auth:*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr create*)",
      "Bash(gh pr checkout*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr status:*)",
      "Bash(gh api *)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh run watch*)",
      "Bash(gh run download*)",
      "Bash(gh run rerun*)",
      "Bash(gh run cancel*)",
      "Bash(gh issue *)",
      "Bash(gh repo view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo audit:*)",
      "Bash(make test-unit)",
      "Bash(go build:*)",
      "Bash(go mod:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(go test:*)",
      "Bash(golangci-lint:*)",
      "Bash(goimports:*)",
      "Bash(npm run:*)",
      "Bash(yarn:*)",
      "Bash(ls*)",
      "Bash(pwd*)",
      "Bash(mkdir*)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(bat *)",
      "Bash(eza:*)",
      "Bash(jq *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(curl *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(gcloud storage ls*)",
      "Bash(gcloud storage cat*)",
      "Bash(gcloud secrets versions access*)",
      "Bash(gcloud secrets list*)",
      "Bash(gcloud run jobs list*)",
      "Bash(gcloud run jobs describe*)",
      "Bash(gcloud run jobs executions describe*)",
      "Bash(gcloud logging read*)",
      "Bash(codex exec:*)",
      "Bash(RUST_LOG=off codex exec:*)",
      "Read(//Users/{{ .chezmoi.username }}/ghq/github.com/riii111/dotfiles/**)",
      "Read(/Users/{{ .chezmoi.username }}/.zshrc)",
      "Read(//Users/{{ .chezmoi.username }}/.config/nvim/**)",
      "Write(//Users/{{ .chezmoi.username }}/.config/nvim/**)",
      "Edit(//Users/{{ .chezmoi.username }}/.config/nvim/**)",
      "Bash(pe *)"
    ],
    "deny": [
{{- if eq .type "work" }}
      "Bash(git push --force*)",
      "Bash(git push -f *)",
{{- end }}
      "Bash(terraform apply:*)",
      "Bash(terraform apply)",
      "Bash(terraform destroy:*)",
      "Bash(terraform destroy)",
      "Bash(sudo:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Read(.aws/**)",
      "Read(.ssh/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/gcloud/**)",
      "Edit(.aws/**)",
      "Edit(.ssh/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.config/gcloud/**)",
      "Write(~/.ssh/**)",
      "Write(~/.config/gcloud/**)",
      "NotebookEdit"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(rmdir:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "context7"
  ],
  "enabledPlugins": {
    "Notion@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "read input; if echo \"$input\" | grep -q '\"command\":\"find'; then echo '{\"decision\": \"block\", \"reason\": \"Use fd instead of find! Example: fd --hidden --exclude .git --exclude node_modules --color=never --print0 <pattern>\"}'; elif echo \"$input\" | grep -q '\"command\":\"grep'; then echo '{\"decision\": \"block\", \"reason\": \"Use rg instead of grep! Example: rg --no-heading --color=never --json --trim --max-columns=120 <pattern>\"}'; elif echo \"$input\" | grep -q '\"command\":\"cat'; then echo '{\"decision\": \"block\", \"reason\": \"Use bat instead of cat! Example: bat --plain --paging=never --color=never <file>\"}';{{ if eq .type "work" }} elif echo \"$input\" | grep -q 'gh pr create' && ! echo \"$input\" | grep -q '\\-\\-draft'; then echo '{\"decision\": \"block\", \"reason\": \"gh pr create without --draft is not allowed. Always use --draft flag.\"}';{{ end }} elif echo \"$input\" | grep -q 'terraform apply'; then echo '{\"decision\": \"block\", \"reason\": \"terraform apply is not allowed directly. Separate it from other commands and let the user approve.\"}'; elif echo \"$input\" | grep -q 'terraform destroy'; then echo '{\"decision\": \"block\", \"reason\": \"terraform destroy is not allowed directly. Separate it from other commands and let the user approve.\"}'; elif echo \"$input\" | grep -q 'npm publish'; then echo '{\"decision\": \"block\", \"reason\": \"npm publish is not allowed directly. Separate it from other commands and let the user approve.\"}'; elif echo \"$input\" | grep -q 'cargo publish'; then echo '{\"decision\": \"block\", \"reason\": \"cargo publish is not allowed directly. Separate it from other commands and let the user approve.\"}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/git-worktree-post-add.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify-impl-review.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "{{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true
}
