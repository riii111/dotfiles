  "env": {
    "RIPGREP_CONFIG_PATH": "{{ .chezmoi.homeDir }}/.ripgreprc",
    "GIT_OPTIONAL_LOCKS": "0",
    "DISABLE_TELEMETRY": "1",
    "RUST_LOG": "info"
  },
  "includeCoAuthoredBy": false,
