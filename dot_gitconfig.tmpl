# ==========================================
# Git Configuration
# ==========================================
# Generated by chezmoi - do not edit directly

# ==========================================
# User Settings (machine-specific)
# ==========================================
[user]
	email = {{ .git_email }}
	name = {{ .git_name }}
{{ if eq .type "personal" }}
	signingkey = {{ .git_signingkey }}

[commit]
	gpgsign = true
{{ else }}

[commit]
	gpgsign = false

# Override user/SSH for personal repos
[includeIf "gitdir:~/ghq/github.com/riii111/"]
	path = ~/.gitconfig-riii111
{{ end }}

# ==========================================
# LFS
# ==========================================
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# ==========================================
# CodeRabbit
# ==========================================
{{ if eq .type "personal" }}
[coderabbit]
	machineId = cli/52733d2426604c81b8c0d83642015439
{{ end }}

# ==========================================
# Core Settings
# ==========================================
[core]
	autocrlf = input
	eol = lf
	safecrlf = true
	pager = delta
	excludesFile = ~/.config/git/ignore

# ==========================================
# Delta Configuration (Beautiful Diffs)
# ==========================================
[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	# Disable syntax highlighting to prevent color rendering issues in lazygit/tcell
	syntax-theme = none
	plus-style = syntax "#2a3a2a"
	minus-style = syntax "#3a2a2a"

# ==========================================
# Merge & Rebase Settings
# ==========================================
[merge]
	conflictstyle = zdiff3

[rebase]
	autoStash = true
	autoSquash = true

# ==========================================
# Diff & Performance Optimization
# ==========================================
[diff]
	algorithm = histogram
	# Disable colorMoved to prevent color conflicts with delta in lazygit/terminal
	# (colorMoved colors override delta's plus-style/minus-style settings)
	colorMoved = no

[fetch]
	writeCommitGraph = true
	prune = true
	pruneTags = true

[pull]
	rebase = false

[push]
	autoSetupRemote = true

# ==========================================
# Git Aliases
# ==========================================
[alias]
	# fzf staging (like GitHub Desktop - multi-select with Tab, confirm with Enter)
	stf = "!git status -s -uall | fzf -m --marker '✔ ' --color 'marker:green:bold' --bind 'ctrl-a:select-all,ctrl-d:deselect-all' --preview 'file=$(echo {} | sed \"s/^...//\" | sed \"s/.* -> //\"); diff=$(git diff HEAD --color=always -- \"$file\" 2>/dev/null); if [ -n \"$diff\" ]; then echo \"$diff\" | delta --no-gitconfig --line-numbers --syntax-theme=Nord; else diff=$(git diff --cached --color=always -- \"$file\" 2>/dev/null); if [ -n \"$diff\" ]; then echo \"$diff\" | delta --no-gitconfig --line-numbers --syntax-theme=Nord; else bat --color=always \"$file\" 2>/dev/null; fi; fi' | sed 's/^...//' | sed 's/.* -> //' | xargs -I {} git add '{}'"

	# Switch branch with fzf (only checked-out branches that still exist)
	swf = "!git reflog | grep 'checkout: moving' | sed 's/.*to //' | sort -u | while read branch; do git rev-parse --verify \"$branch\" >/dev/null 2>&1 && echo \"$branch\"; done | fzf --preview 'git log --oneline --color=always -20 {} 2>/dev/null || echo No commits' | xargs -r git switch"

	# Beautiful log with graph
	logg = log --graph --all --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)'

	# Fixup commit (step 1)
	fixup = "!f() { git commit --fixup \"${1:-HEAD}\"; }; f"

	# Squash fixup commits (step 2)
	squash = "!git rebase -i --autosquash $(git merge-base HEAD $(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@'))"

	# Safe force push (use instead of --force)
	pushf = push --force-with-lease

	# Delete local branches whose remote tracking branch is gone (squash-merge safe)
	# Uses for-each-ref (not branch -v) to avoid false positives from commit messages
	# Skips branches checked out in worktrees to avoid noisy errors
	prune-gone-br = "!f() { git fetch --prune; wt=$(git worktree list --porcelain 2>/dev/null | sed -n 's|^branch refs/heads/||p'); git for-each-ref --format='%(refname:short)%09%(upstream:track)' refs/heads | awk -F '\\t' '$2 == \"[gone]\" { print $1 }' | while IFS= read -r b; do if echo \"$wt\" | grep -qFx \"$b\"; then echo \"Skipped (worktree): $b\"; else git branch -D \"$b\"; fi; done; }; f"

	# Backward-compatible alias for branch cleanup
	prune-gone = prune-gone-br

	# Delete linked worktrees whose checked-out branch tracking branch is gone
	# Preserves the current worktree, the primary worktree, dirty worktrees, and locked worktrees
	prune-gone-wt = "!f() { dry_run=0; case \"$1\" in -n|--dry-run) dry_run=1; shift ;; esac; if [ $# -gt 0 ]; then echo \"Usage: git prune-gone-wt [-n|--dry-run]\" >&2; return 1; fi; git fetch --prune || return; current=$(git rev-parse --path-format=absolute --show-toplevel) || return; primary=$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir)\") || return; tracks=$(git for-each-ref --format='%(refname)%09%(upstream:track)' refs/heads); result=$(git worktree list --porcelain | awk 'BEGIN { path=\"\"; branch=\"\"; detached=0; locked=0; prunable=0 } function flush() { if (path != \"\") { printf \"%s\\t%s\\t%d\\t%d\\t%d\\n\", path, branch, detached, locked, prunable } path=\"\"; branch=\"\"; detached=0; locked=0; prunable=0 } /^worktree / { flush(); path=substr($0, 10); next } /^branch / { branch=substr($0, 8); next } /^detached$/ { detached=1; next } /^locked($| )/ { locked=1; next } /^prunable($| )/ { prunable=1; next } END { flush() }' | while IFS='	' read -r path branch detached locked prunable; do [ -n \"$path\" ] || continue; [ -n \"$branch\" ] || continue; track=$(printf '%s\n' \"$tracks\" | awk -F '\\t' -v ref=\"$branch\" '$1 == ref { print $2 }'); [ \"$track\" = \"[gone]\" ] || continue; name=${branch#refs/heads/}; if [ \"$path\" = \"$current\" ]; then echo \"Skipped (current): $name\"; continue; fi; if [ \"$path\" = \"$primary\" ]; then echo \"Skipped (primary): $name\"; continue; fi; if [ \"$locked\" = \"1\" ]; then echo \"Skipped (locked): $name\"; continue; fi; if [ \"$prunable\" = \"1\" ]; then echo \"Skipped (prunable): $name\"; continue; fi; if [ \"$detached\" = \"1\" ]; then echo \"Skipped (detached): $name\"; continue; fi; if [ -n \"$(git -C \"$path\" status --porcelain 2>/dev/null)\" ]; then echo \"Skipped (dirty): $name\"; continue; fi; if [ \"$dry_run\" -eq 1 ]; then echo \"Would remove (worktree): $name\"; continue; fi; if git worktree remove \"$path\" >/dev/null 2>&1; then echo \"Removed (worktree): $name\"; else echo \"Skipped (remove failed): $name\"; fi; done); if [ -z \"$result\" ]; then echo \"No gone worktrees found\"; return; fi; printf '%s\n' \"$result\"; if [ \"$dry_run\" -eq 1 ]; then removed=$(printf '%s\n' \"$result\" | awk '/^Would remove \\(worktree\\): / { count++ } END { print count + 0 }'); else removed=$(printf '%s\n' \"$result\" | awk '/^Removed \\(worktree\\): / { count++ } END { print count + 0 }'); fi; skipped=$(printf '%s\n' \"$result\" | awk '/^Skipped / { count++ } END { print count + 0 }'); if [ \"$dry_run\" -eq 1 ]; then echo \"Summary: $removed would remove, $skipped skipped\"; else echo \"Summary: $removed removed, $skipped skipped\"; fi; }; f"

	# History fzf - GitHub Desktop History tab like experience
	# - ⬆ mark for unpushed commits
	# - Preview shows changed files + diff
	# - Enter to view full diff in less
	hf = "!f() { \
		unpushed=$(git log --format='%h' @{u}..HEAD 2>/dev/null); \
		git log --color=always \
			--format='%h %C(blue)%ar%C(reset) %s %C(dim)- %an%C(reset)%C(auto)%d' \
			$(git rev-parse --abbrev-ref HEAD) \
		| while IFS= read -r line; do \
			short_hash=$(echo \"$line\" | rg -o '^[a-f0-9]+'); \
			if echo \"$unpushed\" | rg -qF \"$short_hash\"; then \
				printf '⬆ %s\\n' \"$line\"; \
			else \
				printf '  %s\\n' \"$line\"; \
			fi; \
		done \
		| fzf --ansi --no-sort --reverse \
			--header=\"$(git log --oneline @{u}..HEAD 2>/dev/null | wc -l | tr -d ' ') commits ahead of origin\" \
			--preview 'hash=$(echo {} | rg -o \"[a-f0-9]{7,}\" | head -1); git show --stat --color=always $hash && echo && git show $hash --color=always | delta --no-gitconfig --line-numbers --syntax-theme=Nord' \
			--preview-window=right:60% \
			--bind 'enter:execute(hash=$(echo {} | rg -o \"[a-f0-9]{7,}\" | head -1); git show $hash --color=always | delta --no-gitconfig --line-numbers --syntax-theme=Nord | less -R)'; \
	}; f"

# ==========================================
# ghq Settings
# ==========================================
[ghq]
	root = ~/ghq
