# Repo files that shouldn't be in $HOME
Brewfile
README.md
LICENSE
.gitignore
flake.nix
flake.lock
tests
scripts

# Python runtime artifacts
**/__pycache__/**
**/*.pyc

# Personal machine only
{{ if ne .type "personal" }}
.gitconfig-side-work
{{ end }}

# Work machine only
{{ if ne .type "work" }}
.gitconfig-riii111
.claude/skills/deploy-preflight
{{ end }}

# Build artifacts (auto-built by statusline-command.sh)
.claude/statusline/statusline-go
.claude/statusline/.src-hash

# App-managed: rewritten by the Codex desktop app (desktop/plugins/marketplaces/
# node_repl sections). chezmoi apply would clobber those, so config.toml is not
# applied. dot_codex/config.toml.tmpl is kept in-repo as a reference for base
# settings and selected desktop preferences. See its header comment.
.codex/config.toml

# App-managed: written by `wezterm-git-status-bridge setup --herdr` from the
# installed binary. Managing copies here rolled the Lua module back to old
# versions and stripped the plugin script's exec bit on apply; the setup
# command is the single source of truth for these files.
.config/wezterm/right-status.lua
.config/wezterm/herdr-plugin

# Auto-generated files
.config/karabiner/automatic_backups
.config/karabiner/assets

# Machine-specific runtime data (not for sharing)
.config/colima/**
!.config/colima/
!.config/colima/_templates/
!.config/colima/_templates/default.yaml

.config/herdr/**
!.config/herdr/
!.config/herdr/config.toml
