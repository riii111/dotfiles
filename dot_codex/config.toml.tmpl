# =============================================================================
# REFERENCE ONLY — NOT APPLIED BY CHEZMOI
# -----------------------------------------------------------------------------
# The live ~/.codex/config.toml is rewritten by the Codex desktop app (it owns
# the desktop/plugins/marketplaces/node_repl sections), so this file is listed
# in .chezmoiignore and never applied. It is kept here as a hand-maintained
# reference for base settings and desktop preferences worth preserving. To
# change real config, edit the live ~/.codex/config.toml directly; mirror it
# here if you want the reference fresh.
# Maintained occasionally, may drift from live.
# =============================================================================

# =============================================================================
# Global Defaults
# =============================================================================
plan_mode_reasoning_effort = "medium"
review_model = "gpt-5.5"
personality = "pragmatic"
project_doc_max_bytes = 65536

# =============================================================================
# Global Approval Policy
# =============================================================================
sandbox_mode = "workspace-write"
approvals_reviewer = "auto_review"

approval_policy = { granular = {
  sandbox_approval = true,
  rules = true,
  mcp_elicitations = false,
  request_permissions = true,
  skill_approval = false,
} }

[sandbox_workspace_write]
network_access = true
writable_roots = [
  "{{ .chezmoi.homeDir }}/ghq/github.com",
]

model = "gpt-5.5"
model_provider = "openai"
model_reasoning_effort = "high"
model_verbosity = "low"
model_reasoning_summary = "concise"
service_tier = "fast"
web_search = "cached"
hide_agent_reasoning = true

# =============================================================================
# Global Features
# =============================================================================
[features]
fast_mode = true
memories = true

# =============================================================================
# Shell Environment
# =============================================================================
[shell_environment_policy]
inherit = "core"
experimental_use_profile = true

# =============================================================================
# MCP Servers
# =============================================================================
[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]

[mcp_servers.notion]
url = "https://mcp.notion.com/mcp"

# =============================================================================
# Trusted Projects
# =============================================================================
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/riii111/dotfiles"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/ghq/github.com/riii111/sabiql"]
trust_level = "trusted"
{{ if eq .type "personal" }}
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .side_work_org }}/{{ .side_work_project }}"]
trust_level = "trusted"
{{ else }}
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}"]
trust_level = "trusted"
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}-infrastructure"]
trust_level = "trusted"
{{ end }}

[tui]
status_line = ["model-with-reasoning", "git-branch", "context-remaining", "five-hour-limit", "weekly-limit"]

# =============================================================================
# Desktop Preferences
# =============================================================================
[desktop]
composerEnterBehavior = "cmdIfMultiline"
appearanceLightCodeThemeId = "linear"
appearanceDarkCodeThemeId = "sentry"
appearanceTheme = "system"
git-branch-prefix = ""
git-pr-instructions = """
- .github配下にpull request templateがあればそれに準拠。
- 内容について
  変更内容は、diffを見ればわかるレベルの内容は冗長なので書かない。物理レベルではなく論理レベルでの情報を記述する。"""
git-commit-instructions = """
Conventional Commitに準拠。
bodyは指示されない限りは書かない。タイトルだけで表現"""
default-service-tier = "priority"

[desktop.open-in-target-preferences]
global = "ghostty"

[desktop.appearanceLightChromeTheme]
accent = "#5e6ad2"
contrast = 40
ink = "#1b1b1b"
opaqueWindows = false
surface = "#f7f7f7"

[desktop.appearanceLightChromeTheme.fonts]
ui = "Inter"
code = '"Geist Mono", ui-monospace, "SFMono-Regular"'

[desktop.appearanceLightChromeTheme.semanticColors]
diffAdded = "#52a450"
diffRemoved = "#c94446"
skill = "#8160d8"

[desktop.appearanceDarkChromeTheme]
accent = "#7055f6"
contrast = 60
ink = "#e6dff9"
opaqueWindows = false
surface = "#1a171f"

[desktop.appearanceDarkChromeTheme.fonts]
ui = "Inter"

[desktop.appearanceDarkChromeTheme.semanticColors]
diffAdded = "#8ee6d7"
diffRemoved = "#fa423e"
skill = "#7055f6"
