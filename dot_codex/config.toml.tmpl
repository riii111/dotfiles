# =============================================================================
# REFERENCE ONLY — NOT APPLIED BY CHEZMOI
# -----------------------------------------------------------------------------
# The live ~/.codex/config.toml is rewritten by the Codex desktop app (it owns
# the desktop/plugins/marketplaces/node_repl sections), so this file is listed
# in .chezmoiignore and never applied. It is kept here as a hand-maintained
# reference for the base settings below. To change real config, edit the live
# ~/.codex/config.toml directly; mirror it here if you want the reference fresh.
# Maintained occasionally, may drift from live.
# =============================================================================

# =============================================================================
# Global Defaults
# =============================================================================
plan_mode_reasoning_effort = "medium"
review_model = "gpt-5.5"
personality = "pragmatic"
project_doc_max_bytes = 65536

# =============================================================================
# Global Approval Policy
# =============================================================================
approval_policy = { granular = {
  sandbox_approval = true,
  rules = true,
  mcp_elicitations = false,
  request_permissions = false,
  skill_approval = false,
} }

sandbox_mode = "danger-full-access"
model = "gpt-5.5"
model_provider = "openai"
model_reasoning_effort = "high"
model_verbosity = "low"
model_reasoning_summary = "concise"
service_tier = "fast"
web_search = "cached"
hide_agent_reasoning = true

# =============================================================================
# Global Features
# =============================================================================
[features]
fast_mode = true
memories = true

# =============================================================================
# Shell Environment
# =============================================================================
[shell_environment_policy]
inherit = "core"
experimental_use_profile = true

# =============================================================================
# MCP Servers
# =============================================================================
[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]

[mcp_servers.notion]
url = "https://mcp.notion.com/mcp"

# =============================================================================
# Trusted Projects
# =============================================================================
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/riii111/dotfiles"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/ghq/github.com/riii111/sabiql"]
trust_level = "trusted"
{{ if eq .type "personal" }}
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .side_work_org }}/{{ .side_work_project }}"]
trust_level = "trusted"
{{ else }}
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}"]
trust_level = "trusted"
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}-infrastructure"]
trust_level = "trusted"
{{ end }}

[tui]
status_line = ["model-with-reasoning", "git-branch", "context-remaining", "five-hour-limit", "weekly-limit"]
