model = "gpt-5.4-mini"
model_provider = "openai"
model_reasoning_effort = "medium"
plan_mode_reasoning_effort = "high"
review_model = "gpt-5.4"
web_search = "cached"
personality = "pragmatic"
service_tier = "fast"
project_doc_max_bytes = 65536

approval_policy = { granular = {
  sandbox_approval = true,
  rules = true,
  mcp_elicitations = false,
  request_permissions = false,
  skill_approval = false,
} }

sandbox_mode = "workspace-write"

[features]
fast_mode = true

[sandbox_workspace_write]
network_access = false
exclude_slash_tmp = false
exclude_tmpdir_env_var = false

[shell_environment_policy]
inherit = "core"
experimental_use_profile = true

[permissions.safe_web.network]
enabled = true
mode = "limited"
allowed_domains = [
  "github.com",
  "raw.githubusercontent.com",
  "registry.npmjs.org",
  "pypi.org",
  "go.dev",
  "pkg.go.dev",
  "docs.rs",
]
denied_domains = []

[profiles.implement]
model = "gpt-5.4-mini"
model_provider = "openai"
model_reasoning_effort = "medium"
service_tier = "fast"
web_search = "cached"

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]

[mcp_servers.notion]
url = "https://mcp.notion.com/mcp"

[projects."{{ .chezmoi.homeDir }}/ghq/github.com/riii111/dotfiles"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/ghq/github.com/riii111/kotlin-language-server"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/ghq/github.com/riii111/sabiql"]
trust_level = "trusted"
{{ if eq .type "personal" }}
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .side_work_org }}/{{ .side_work_project }}"]
trust_level = "trusted"
{{ else }}
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}"]
trust_level = "trusted"
[projects."{{ .chezmoi.homeDir }}/ghq/github.com/{{ .gh_work_org }}/{{ .work_project }}-infrastructure"]
trust_level = "trusted"
{{ end }}
